# =============================================================================
# FutureKawa — Variables d'environnement
# Copier ce fichier : cp .env.example .env
# Remplir TOUTES les valeurs avant de lancer docker compose up
# Ne jamais commiter le fichier .env
# =============================================================================


# ── Pays actif ────────────────────────────────────────────────────────────────
# Valeur possible : bresil | equateur | colombie
PAYS=


# ── Base de données PAYS ──────────────────────────────────────────────────────
PAYS_DB_USER=
PAYS_DB_PASSWORD=
PAYS_DB_NAME=


# ── Base de données CENTRALE (utilisateurs, rôles) ────────────────────────────
CENTRAL_DB_USER=
CENTRAL_DB_PASSWORD=


# ── JWT (clé secrète partagée entre backend-central et backend-pays) ──────────
# Minimum 32 caractères, aléatoire — ex: openssl rand -hex 32
JWT_SECRET=


# ── Compte administrateur (créé au premier démarrage) ────────────────────────
ADMIN_EMAIL=
ADMIN_PASSWORD=


# ── URLs des backends pays (depuis backend-central standalone) ────────────────
COUNTRY_BRESIL_URL=
COUNTRY_EQUATEUR_URL=
COUNTRY_COLOMBIE_URL=


# ── Email alertes ─────────────────────────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=
SENDER_PASSWORD=


# ── Ports hôte (pour lancer plusieurs pays en parallèle) ─────────────────────
API_PORT=
POSTGRES_PORT=
MOSQUITTO_PORT=
