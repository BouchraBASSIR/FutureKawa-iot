{
  "env": {
    "test": {
      "presets": [
        [
          "@babel/preset-env",
          {
            "targets": [
              "last 2 chrome versions",
              "last 2 firefox versions",
              "edge 17",
              "ie 11"
            ]
          }
        ],
        "@babel/preset-react"
      ],
      "plugins": [
        "@babel/plugin-syntax-dynamic-import",
        "@babel/plugin-proposal-class-properties",
        "@babel/plugin-proposal-optional-chaining"
      ]
    },
    "development": {
      "presets": [
        [
          "@babel/preset-env",
          {
            "modules": false,
            "useBuiltIns": "entry",
            "corejs": "3",
            "targets": [
              "last 2 chrome versions",
              "last 2 firefox versions",
              "edge 17",
              "ie 11"
            ]
          }
        ],
        "@babel/preset-react"
      ]
    },
    "production": {
      "presets": [
        [
          "@babel/preset-env",
          {
            "modules": false,
            "useBuiltIns": "entry",
            "corejs": "3",
            "targets": [
              "last 2 chrome versions",
              "last 2 firefox versions",
              "edge 17",
              "ie 11"
            ]
          }
        ],
        "@babel/preset-react"
      ],
      "plugins": [
        "@babel/plugin-proposal-export-default-from",
        "@babel/plugin-syntax-dynamic-import",
        "@babel/plugin-proposal-class-properties",
        "@babel/plugin-proposal-optional-chaining",
        "babel-plugin-lodash",
        [
          "import",
          {
            "libraryName": "antd",
            "style": "css"
          }
        ]
      ]
    }
  }
}