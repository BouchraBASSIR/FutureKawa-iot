# ── Identité du pays ──────────────────────────────────────────
PAYS=bresil           # bresil | equateur | colombie

# ── Base de données ───────────────────────────────────────────
POSTGRES_USER=futurekawa
POSTGRES_PASSWORD=futurekawa123
POSTGRES_DB=futurekawa_bresil      # changer par pays : futurekawa_equateur, futurekawa_colombie
POSTGRES_PORT=5432                 # port hôte pour éviter conflit si plusieurs pays lancés

DATABASE_URL=postgresql://futurekawa:futurekawa123@postgres:5432/futurekawa_bresil

# ── MQTT ──────────────────────────────────────────────────────
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MOSQUITTO_PORT=1883                # port hôte (ex: 1883/1884/1885 selon le pays)

# ── API ───────────────────────────────────────────────────────
API_PORT=8000                      # port hôte (ex: 8000/8001/8002 selon le pays)

# ── Email alertes ─────────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=alerts@futurekawa.com
SENDER_PASSWORD=app-password-gmail

# Exemples de configuration par pays :
#
#  Brésil    : PAYS=bresil    POSTGRES_DB=futurekawa_bresil    API_PORT=8000 MOSQUITTO_PORT=1883
#  Équateur  : PAYS=equateur  POSTGRES_DB=futurekawa_equateur  API_PORT=8001 MOSQUITTO_PORT=1884
#  Colombie  : PAYS=colombie  POSTGRES_DB=futurekawa_colombie  API_PORT=8002 MOSQUITTO_PORT=1885
