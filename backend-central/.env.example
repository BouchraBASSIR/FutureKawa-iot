# ================================================================
# FutureKawa — Backend Central : variables d'environnement
#
# Copier ce fichier en .env et renseigner les valeurs réelles.
# Le fichier .env ne doit JAMAIS être commité (voir .gitignore).
# ================================================================

# ── URLs des backends pays ────────────────────────────────────────
# Format : protocole + hôte + port (sans slash final)
# Utiliser host.docker.internal pour atteindre l'hôte depuis Docker.

COUNTRY_BRESIL_URL=http://localhost:8000
COUNTRY_EQUATEUR_URL=http://localhost:8001
COUNTRY_COLOMBIE_URL=http://localhost:8002

# ── Alternative : configuration dynamique multi-pays ─────────────
# Décommenter pour surcharger les trois variables ci-dessus.
# Format : id:NomPays:url,...
# Exemple :
# COUNTRIES_CONFIG=bresil:Brésil:http://192.168.1.10:8000,equateur:Équateur:http://192.168.1.11:8000,colombie:Colombie:http://192.168.1.12:8000
